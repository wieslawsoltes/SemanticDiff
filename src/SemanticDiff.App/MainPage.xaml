<Page x:Class="SemanticDiff.App.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="using:SemanticDiff.App.Views"
      xmlns:viewModels="using:SemanticDiff.App.ViewModels"
      Background="{ThemeResource AppBackgroundBrush}">
  <Page.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0F14" />
          <SolidColorBrush x:Key="ChromeBrush" Color="#101721" />
          <SolidColorBrush x:Key="PanelBrush" Color="#0F151D" />
          <SolidColorBrush x:Key="PanelRaisedBrush" Color="#141C27" />
          <SolidColorBrush x:Key="CanvasBrush" Color="#0C1118" />
          <SolidColorBrush x:Key="BorderBrush" Color="#263140" />
          <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1B2430" />
          <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E6EDF5" />
          <SolidColorBrush x:Key="SecondaryTextBrush" Color="#99A6B6" />
          <SolidColorBrush x:Key="TertiaryTextBrush" Color="#6F7B8B" />
          <SolidColorBrush x:Key="AccentBrush" Color="#58A6D6" />
          <SolidColorBrush x:Key="AccentMutedBrush" Color="#183142" />
          <SolidColorBrush x:Key="PositiveBrush" Color="#55B886" />
          <SolidColorBrush x:Key="WarningBrush" Color="#D7B46A" />
          <SolidColorBrush x:Key="WarningMutedBrush" Color="#352B16" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F6F9" />
          <SolidColorBrush x:Key="ChromeBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="PanelBrush" Color="#EEF2F6" />
          <SolidColorBrush x:Key="PanelRaisedBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="CanvasBrush" Color="#F7F9FC" />
          <SolidColorBrush x:Key="BorderBrush" Color="#C9D3E0" />
          <SolidColorBrush x:Key="SubtleBorderBrush" Color="#DDE4EE" />
          <SolidColorBrush x:Key="PrimaryTextBrush" Color="#142033" />
          <SolidColorBrush x:Key="SecondaryTextBrush" Color="#526172" />
          <SolidColorBrush x:Key="TertiaryTextBrush" Color="#7A8796" />
          <SolidColorBrush x:Key="AccentBrush" Color="#166B9A" />
          <SolidColorBrush x:Key="AccentMutedBrush" Color="#DDEFF8" />
          <SolidColorBrush x:Key="PositiveBrush" Color="#187A54" />
          <SolidColorBrush x:Key="WarningBrush" Color="#9A6D16" />
          <SolidColorBrush x:Key="WarningMutedBrush" Color="#F6E9C8" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="ChromeButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="11,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="CompactToggleStyle" TargetType="ToggleButton">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource AccentMutedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="CompactListViewItemStyle" TargetType="ListViewItem">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="WorkspaceTabListViewItemStyle" TargetType="ListViewItem">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="GitHistoryListViewItemStyle" TargetType="ListViewItem">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="TreeDisclosureButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{ThemeResource TertiaryTextBrush}" />
    </Style>

    <Style x:Key="WorkspaceTabCloseButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{ThemeResource TertiaryTextBrush}" />
    </Style>

    <DataTemplate x:Key="WorkspaceTabHeaderTemplate">
      <Grid MinHeight="30" MinWidth="104" Padding="10,0" Tag="{Binding}">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" VerticalAlignment="Center">
          <TextBlock Text="{Binding IconGlyph}"
                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     Foreground="{ThemeResource AccentBrush}"
                     FontSize="13"
                     VerticalAlignment="Center"
                     Visibility="{Binding IconVisibility}" />
          <TextBlock Grid.Column="1"
                     Text="{Binding Header}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
          <Button Grid.Column="2"
                  Content="x"
                  Tag="{Binding}"
                  Width="20"
                  Height="20"
                  Padding="0"
                  Style="{StaticResource WorkspaceTabCloseButtonStyle}"
                  Visibility="{Binding CloseButtonVisibility}"
                  Click="OnWorkspaceTabCloseClicked" />
        </Grid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="GitHistoryRefBadgeTemplate">
      <Border Padding="5,1"
              Margin="0,0,4,0"
              CornerRadius="4"
              BorderThickness="1"
              Background="{Binding Background}"
              BorderBrush="{Binding Border}">
        <TextBlock Text="{Binding Text}"
                   Foreground="{Binding Foreground}"
                   FontSize="9"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis" />
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="GitHistoryGraphPathTemplate">
      <Path Data="{Binding Data}"
            Stroke="{Binding Stroke}"
            StrokeThickness="{Binding StrokeThickness}"
            Opacity="{Binding Opacity}"
            IsHitTestVisible="False" />
    </DataTemplate>

    <DataTemplate x:Key="GitHistoryItemTemplate">
      <Grid MinHeight="{Binding RowMinHeight}"
            Tag="{Binding}"
            RightTapped="OnGitHistoryItemRightTapped">
        <Grid ColumnDefinitions="214,78,*,Auto" ColumnSpacing="8" Margin="10,0">
          <Canvas Width="{Binding GraphWidth}"
                  Height="{Binding RowHeight}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  IsHitTestVisible="False">
            <ItemsControl ItemsSource="{Binding GraphPaths}"
                          ItemTemplate="{StaticResource GitHistoryGraphPathTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Canvas />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <Ellipse Canvas.Left="{Binding DotLeft}"
                     Canvas.Top="{Binding DotTop}"
                     Width="{Binding DotSize}"
                     Height="{Binding DotSize}"
                     Fill="{Binding DotBrush}"
                     Stroke="{Binding DotStroke}"
                     StrokeThickness="2" />
          </Canvas>
          <TextBlock Grid.Column="1"
                     Text="{Binding ShortId}"
                     Foreground="{ThemeResource AccentBrush}"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="11"
                     FontWeight="SemiBold"
                     VerticalAlignment="Top"
                     Margin="0,13,0,0" />
          <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto" RowSpacing="4" Margin="0,9,0,0">
            <TextBlock Text="{Binding Subject}"
                       Foreground="{ThemeResource PrimaryTextBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding RefBadges}"
                          ItemTemplate="{StaticResource GitHistoryRefBadgeTemplate}"
                          Visibility="{Binding DecorationsVisibility}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <TextBlock Grid.Row="2"
                       Text="{Binding MetaText}"
                       Foreground="{ThemeResource SecondaryTextBrush}"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis" />
          </Grid>
          <Border Grid.Column="3"
                  Padding="6,1"
                  CornerRadius="4"
                  Background="{ThemeResource WarningMutedBrush}"
                  Margin="0,9,0,0"
                  VerticalAlignment="Top"
                  Visibility="{Binding MergeVisibility}">
            <TextBlock Text="{Binding MergeText}" Foreground="{ThemeResource WarningBrush}" FontSize="9" FontWeight="SemiBold" />
          </Border>
        </Grid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="FileDiffLineTemplate">
      <Grid MinHeight="22" Padding="8,1">
        <Grid ColumnDefinitions="44,44,26,*" ColumnSpacing="6">
          <TextBlock Text="{Binding OldLineNumberText}" Foreground="{ThemeResource TertiaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" HorizontalAlignment="Right" />
          <TextBlock Grid.Column="1" Text="{Binding NewLineNumberText}" Foreground="{ThemeResource TertiaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" HorizontalAlignment="Right" />
          <TextBlock Grid.Column="2" Text="{Binding Marker}" Foreground="{ThemeResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" />
          <TextBlock Grid.Column="3" Text="{Binding Text}" Foreground="{ThemeResource PrimaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12" TextTrimming="CharacterEllipsis" />
        </Grid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="BlameCommitNodeTemplate">
      <Grid MinHeight="96" ColumnDefinitions="42,*" Padding="14,4">
        <Grid>
          <Border Width="3"
                  Background="{Binding AccentBrush}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  CornerRadius="2" />
          <Ellipse Width="15"
                   Height="15"
                   Fill="{Binding AccentBrush}"
                   Stroke="{ThemeResource ChromeBrush}"
                   StrokeThickness="2"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,12,0,0" />
        </Grid>
        <Border Grid.Column="1"
                Background="{Binding SoftBrush}"
                BorderBrush="{Binding AccentBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="7">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
              <TextBlock Text="{Binding ShortId}"
                         Foreground="{ThemeResource AccentBrush}"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding Summary}"
                         Foreground="{ThemeResource PrimaryTextBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <Border Grid.Column="2"
                      Background="{ThemeResource ChromeBrush}"
                      BorderBrush="{Binding AccentBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="8,2">
                <TextBlock Text="{Binding LineCountText}"
                           Foreground="{ThemeResource PrimaryTextBrush}"
                           FontSize="10"
                           FontWeight="SemiBold" />
              </Border>
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="{Binding Author}"
                       Foreground="{ThemeResource SecondaryTextBrush}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBlock Text="{Binding LineRangeText}"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Column="1"
                         Text="{Binding TimeText}"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontSize="10" />
            </Grid>
            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8">
              <TextBlock Text="{Binding CoverageText}"
                         Foreground="{ThemeResource SecondaryTextBrush}"
                         FontSize="10"
                         VerticalAlignment="Center" />
              <Grid Grid.Column="1"
                    Height="8"
                    Background="{ThemeResource SubtleBorderBrush}"
                    VerticalAlignment="Center">
                <Border Width="{Binding CoverageWidth}"
                        Background="{Binding AccentBrush}"
                        HorizontalAlignment="Left"
                        CornerRadius="4" />
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="BlameTimelineItemTemplate">
      <Border Width="178"
              MinHeight="82"
              Margin="0,0,8,0"
              Padding="10,8"
              CornerRadius="7"
              Background="{Binding SoftBrush}"
              BorderBrush="{Binding AccentBrush}"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7">
            <Border Width="8"
                    Height="{Binding MarkerHeight}"
                    Background="{Binding AccentBrush}"
                    CornerRadius="4"
                    VerticalAlignment="Top" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ShortId}"
                       Foreground="{ThemeResource AccentBrush}"
                       FontFamily="Cascadia Mono, Consolas"
                       FontSize="10"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="2"
                       Text="{Binding TimeText}"
                       Foreground="{ThemeResource TertiaryTextBrush}"
                       FontSize="9" />
          </Grid>
          <TextBlock Grid.Row="1"
                     Text="{Binding Subject}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="2"
                     Text="{Binding Author}"
                     Foreground="{ThemeResource SecondaryTextBrush}"
                     FontSize="10"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="3"
                     Text="{Binding BlamedLineText}"
                     Foreground="{ThemeResource WarningBrush}"
                     FontSize="9"
                     FontWeight="SemiBold"
                     Visibility="{Binding BlamedLineVisibility}" />
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="WorkspaceTabContentTemplate">
      <Grid Background="{ThemeResource CanvasBrush}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid Visibility="{Binding HistoryVisibility}" RowDefinitions="Auto,*">
          <Border Background="{ThemeResource ChromeBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock Text="{Binding History.Title}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding History.CountText}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Grid.Row="1" Text="{Binding History.RangeText}" Foreground="{ThemeResource TertiaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
            </Grid>
          </Border>
          <Grid Grid.Row="1" RowDefinitions="*,Auto">
            <TextBlock Text="{Binding StatusText}" Foreground="{ThemeResource SecondaryTextBrush}" Margin="18,14" Visibility="{Binding LoadingVisibility}" />
            <ListView ItemsSource="{Binding History.Commits}"
                      ItemTemplate="{StaticResource GitHistoryItemTemplate}"
                      ItemContainerStyle="{StaticResource GitHistoryListViewItemStyle}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      SelectionMode="None"
                      ContainerContentChanging="OnGitHistoryContainerContentChanging" />
            <Border Grid.Row="1"
                    Background="{ThemeResource ChromeBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,7"
                    Visibility="{Binding History.FooterVisibility}">
              <TextBlock Text="{Binding History.FooterText}"
                         Foreground="{ThemeResource SecondaryTextBrush}"
                         FontSize="11" />
            </Border>
          </Grid>
        </Grid>

        <Grid Visibility="{Binding FileDiffVisibility}" RowDefinitions="Auto,*">
          <Border Background="{ThemeResource ChromeBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="7">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding FileDiff.Path}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding FileDiff.SummaryText}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                  <ToggleButton Content="Diff only" Tag="DiffOnly" IsChecked="{Binding FileDiff.IsDiffOnlyMode, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFileDiffModeClicked" />
                  <ToggleButton Grid.Column="1" Content="Full file" Tag="FullFile" IsChecked="{Binding FileDiff.IsFullFileMode, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFileDiffModeClicked" />
                  <ToggleButton Grid.Column="2" Content="Changes" Tag="Changes" IsChecked="{Binding FileDiff.IsChangesDiffScopeMode, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFileDiffScopeModeClicked" />
                  <ToggleButton Grid.Column="3" Content="Full diff" Tag="FullFileDiff" IsChecked="{Binding FileDiff.IsFullFileDiffScopeMode, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFileDiffScopeModeClicked" />
                  <ToggleButton Grid.Column="4"
                                Content="Annotations"
                                IsChecked="{Binding FileDiff.IsDiffAnnotationEnabled, Mode=OneWay}"
                                Style="{StaticResource CompactToggleStyle}"
                                Click="OnFileDiffAnnotationToggleClicked" />
                  <TextBlock Grid.Column="5"
                             Text="Font"
                             Foreground="{ThemeResource TertiaryTextBrush}"
                             FontSize="11"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="6"
                          Content="-"
                          MinWidth="32"
                          Padding="8,4"
                          IsEnabled="{Binding FileDiff.CanDecreaseCodeFontSize}"
                          Style="{StaticResource ChromeButtonStyle}"
                          Click="OnFileDiffDecreaseFontSizeClicked" />
                  <ComboBox Grid.Column="7"
                            Width="82"
                            MinHeight="30"
                            ItemsSource="{Binding FileDiff.CodeFontSizeOptions}"
                            SelectedItem="{Binding FileDiff.CodeFontSize, Mode=TwoWay}"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnFileDiffFontSizeSelectionChanged" />
                  <Button Grid.Column="8"
                          Content="+"
                          MinWidth="32"
                          Padding="8,4"
                          IsEnabled="{Binding FileDiff.CanIncreaseCodeFontSize}"
                          Style="{StaticResource ChromeButtonStyle}"
                          Click="OnFileDiffIncreaseFontSizeClicked" />
                  <Button Grid.Column="9"
                          Content="Blame"
                          Tag="{Binding}"
                          Style="{StaticResource ChromeButtonStyle}"
                          Click="OnFileDiffOpenBlameClicked" />
                </Grid>
              </Grid>
            </Grid>
          </Border>
          <Grid Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid Visibility="{Binding FileDiff.DiffOnlyVisibility}" RowDefinitions="Auto,*" Padding="14">
              <TextBlock Text="{Binding FileDiff.DiffOnlyHeader}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,8" />
              <views:CodeFileViewerControl Grid.Row="1"
                                           Lines="{Binding FileDiff.CurrentDiffOnlyLines}"
                                           IsDiffMode="True"
                                           ShowDiffAnnotations="{Binding FileDiff.IsDiffAnnotationEnabled}"
                                           CodeFontSize="{Binding FileDiff.CodeFontSize, Mode=TwoWay}"
                                           RefreshKey="{Binding FileDiff.RefreshKey}"
                                           LineContextRequested="OnFileViewerLineContextRequested" />
            </Grid>
            <Grid Visibility="{Binding FileDiff.FullFileVisibility}" RowDefinitions="Auto,*" Padding="14">
              <TextBlock Text="{Binding FileDiff.FullFileHeader}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,8" />
              <views:CodeFileViewerControl Grid.Row="1"
                                           Lines="{Binding FileDiff.CurrentFullFileLines}"
                                           FoldRegions="{Binding FileDiff.FoldRegions}"
                                           ShowDiffAnnotations="{Binding FileDiff.IsDiffAnnotationEnabled}"
                                           CodeFontSize="{Binding FileDiff.CodeFontSize, Mode=TwoWay}"
                                           RefreshKey="{Binding FileDiff.RefreshKey}"
                                           LineContextRequested="OnFileViewerLineContextRequested" />
            </Grid>
          </Grid>
        </Grid>

        <Grid Visibility="{Binding BlameVisibility}" RowDefinitions="Auto,*,Auto">
          <Border Background="{ThemeResource ChromeBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding Blame.Path}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Blame.SummaryText}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                  <ToggleButton Content="Timeline"
                                Tag="CommitTimeline"
                                IsChecked="{Binding Blame.IsCommitTimelineMode, Mode=OneWay}"
                                Style="{StaticResource CompactToggleStyle}"
                                Click="OnBlameDisplayModeClicked" />
                  <ToggleButton Grid.Column="1"
                                Content="Change graph"
                                Tag="ChangeGraph"
                                IsChecked="{Binding Blame.IsChangeGraphMode, Mode=OneWay}"
                                Style="{StaticResource CompactToggleStyle}"
                                Click="OnBlameDisplayModeClicked" />
                </Grid>
                <Button Grid.Column="2"
                        Content="{Binding Blame.TimelineToggleText}"
                        Tag="{Binding}"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="OnBlameTimelineToggleClicked" />
              </Grid>
            </Grid>
          </Border>
          <Grid Grid.Row="1">
            <TextBlock Text="{Binding StatusText}" Foreground="{ThemeResource SecondaryTextBrush}" Margin="18,14" Visibility="{Binding LoadingVisibility}" />
            <TextBlock Text="No blame data available for this file."
                       Foreground="{ThemeResource SecondaryTextBrush}"
                       Margin="18,14"
                       Visibility="{Binding Blame.EmptyVisibility}" />
            <ScrollViewer Visibility="{Binding Blame.CommitTimelineVisibility}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding Blame.CommitNodes}"
                            ItemTemplate="{StaticResource BlameCommitNodeTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>
            <Grid Visibility="{Binding Blame.ChangeGraphVisibility}" RowDefinitions="Auto,*">
              <Border Background="{ThemeResource PanelBrush}"
                      BorderBrush="{ThemeResource BorderBrush}"
                      BorderThickness="0,0,0,1"
                      Padding="14,8">
                <TextBlock Text="{Binding Blame.ChangeGraphSummaryText}"
                           Foreground="{ThemeResource SecondaryTextBrush}"
                           FontSize="10"
                           TextTrimming="CharacterEllipsis" />
              </Border>
              <views:DiffCanvasControl Grid.Row="1"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Scene="{Binding Blame.ChangeGraphScene}"
                                       IsLightTheme="{Binding IsLightTheme}"
                                       NodeNavigationRequested="OnDiffCanvasNodeNavigationRequested"
                                       NodeDiffTabRequested="OnDiffCanvasNodeDiffTabRequested"
                                       NodeBlameTabRequested="OnDiffCanvasNodeBlameTabRequested"
                                       NodeSymbolGraphRequested="OnDiffCanvasNodeSymbolGraphRequested" />
            </Grid>
          </Grid>
          <Border Grid.Row="2"
                  Background="{ThemeResource ChromeBrush}"
                  BorderBrush="{ThemeResource BorderBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="14,8"
                  Visibility="{Binding Blame.CollapsedTimelineVisibility}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="7">
              <TextBlock Text="File history timeline"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontSize="10"
                         FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Blame.TimelineItems}"
                              ItemTemplate="{StaticResource BlameTimelineItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
          <Border Grid.Row="2"
                  Background="{ThemeResource ChromeBrush}"
                  BorderBrush="{ThemeResource BorderBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="14,8"
                  MaxHeight="242"
                  Visibility="{Binding Blame.ExpandedTimelineVisibility}">
            <Grid RowDefinitions="Auto,*" RowSpacing="7">
              <TextBlock Text="Expanded file history timeline"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontSize="10"
                         FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Blame.TimelineItems}"
                              ItemTemplate="{StaticResource BlameTimelineItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>

        <Grid Visibility="{Binding SymbolGraphVisibility}" RowDefinitions="Auto,*">
          <Border Background="{ThemeResource ChromeBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="7">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding SymbolGraph.Title}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding SymbolGraph.SummaryText}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Reset filters"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="OnSymbolGraphResetFiltersClicked" />
              </Grid>
              <TextBox Grid.Row="1"
                       Text="{Binding SymbolGraph.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Filter symbols by name, file, kind, changed, linked" />
              <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*,Auto,Auto,Auto" ColumnSpacing="7">
                <ComboBox ItemsSource="{Binding SymbolGraph.ScopeOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedScopeOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SymbolGraph.KindOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedKindOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding SymbolGraph.DocumentOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedDocumentOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding SymbolGraph.EdgeKindOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedEdgeKindOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
                <ComboBox Grid.Column="4"
                          Width="132"
                          ItemsSource="{Binding SymbolGraph.ViewModeOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedViewModeOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
                <ComboBox Grid.Column="5"
                          Width="132"
                          ItemsSource="{Binding SymbolGraph.LayoutOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedLayoutOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
                <ComboBox Grid.Column="6"
                          Width="132"
                          ItemsSource="{Binding SymbolGraph.GroupingOptions}"
                          SelectedItem="{Binding SymbolGraph.SelectedGroupingOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource CompactComboBoxStyle}" />
              </Grid>
            </Grid>
          </Border>
          <Grid Grid.Row="1">
            <TextBlock Text="No symbols match this graph filter."
                       Foreground="{ThemeResource SecondaryTextBrush}"
                       Margin="18,14"
                       Visibility="{Binding SymbolGraph.EmptyVisibility}" />
            <views:DiffCanvasControl HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Visibility="{Binding SymbolGraph.ContentVisibility}"
                                     Scene="{Binding SymbolGraph.Scene}"
                                     IsLightTheme="{Binding IsLightTheme}"
                                     NodeNavigationRequested="OnDiffCanvasNodeNavigationRequested"
                                     NodeDiffTabRequested="OnDiffCanvasNodeDiffTabRequested"
                                     NodeBlameTabRequested="OnDiffCanvasNodeBlameTabRequested"
                                     NodeSymbolGraphRequested="OnDiffCanvasNodeSymbolGraphRequested" />
            <Border HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="12"
                    Background="{ThemeResource ChromeBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10,6">
              <TextBlock Text="{Binding SymbolGraph.FilterStatusText}"
                         Foreground="{ThemeResource SecondaryTextBrush}"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis" />
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </DataTemplate>

