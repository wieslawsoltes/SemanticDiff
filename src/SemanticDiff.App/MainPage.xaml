    <DataTemplate x:Key="SettingsPanelTemplate" x:DataType="viewModels:MainViewModel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12" Padding="0,8,4,6">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Diff Scope" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind DiffScopeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Worktree" IsChecked="{x:Bind IsWorktreeScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnWorktreeScopeClicked" />
                    <ToggleButton Grid.Column="1" Content="Unstaged" IsChecked="{x:Bind IsUnstagedScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnUnstagedScopeClicked" />
                    <ToggleButton Grid.Row="1" Content="Staged" IsChecked="{x:Bind IsStagedScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnStagedScopeClicked" />
                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="Branch" IsChecked="{x:Bind IsBranchScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnBranchScopeClicked" />
                    <ToggleButton Grid.Row="2" Grid.ColumnSpan="2" Content="Range" IsChecked="{x:Bind IsRangeScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnRangeScopeClicked" />
                    <TextBox x:Name="BaseRefTextBox"
                             Grid.Row="3"
                             Text="{x:Bind BaseRefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             PlaceholderText="Start/base ref" />
                    <TextBox x:Name="HeadRefTextBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Text="{x:Bind HeadRefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             PlaceholderText="End/head ref" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="{x:Bind ReferenceSelectorStatusText, Mode=OneWay}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{x:Bind DiffViewCacheText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Button Content="Apply refs" Style="{StaticResource ChromeButtonStyle}" Click="OnApplyRefsClicked" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Repository" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind WatchStatusText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                  </Grid>
                  <Grid>
                    <ToggleButton Content="Auto refresh" IsChecked="{x:Bind IsAutoRefreshEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnAutoRefreshClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Semantic Analysis" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind SemanticAnalysisModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="MSBuild" IsChecked="{x:Bind IsSemanticWorkspaceModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticWorkspaceModeClicked" />
                    <ToggleButton Grid.Column="1" Content="Fast syntax" IsChecked="{x:Bind IsSemanticFastModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticFastModeClicked" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Text="Code Completion" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind CodeCompletionModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="Language services" IsChecked="{x:Bind IsCompletionLanguageServicesModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnCompletionLanguageServicesModeClicked" />
                    <ToggleButton Grid.Column="1" Content="Document" IsChecked="{x:Bind IsCompletionDocumentModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnCompletionDocumentModeClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Layout" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind LayoutModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <ComboBox ItemsSource="{x:Bind LayoutModeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind SelectedLayoutModeOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnLayoutModeSelectionChanged" />
                  <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Text="Grouping" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind GroupingModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <ComboBox ItemsSource="{x:Bind GroupingModeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind SelectedGroupingModeOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnGroupingModeSelectionChanged" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Context" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind DiffContextModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Changed" IsChecked="{x:Bind IsChangedHunksContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnChangedHunksContextClicked" />
                    <ToggleButton Grid.Column="1" Content="Full diff" IsChecked="{x:Bind IsFullFileDiffContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFullFileDiffContextClicked" />
                    <ToggleButton Grid.Row="1" Grid.ColumnSpan="2" Content="Current file" IsChecked="{x:Bind IsCurrentFileContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnCurrentFileContextClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Review" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ReviewRequestStateText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <ComboBox ItemsSource="{x:Bind ReviewRequestStateOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind SelectedReviewRequestStateOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnReviewRequestStateSelectionChanged" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ToggleButton Content="Noise filter" IsChecked="{x:Bind IsNoiseFilterEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnNoiseFilterClicked" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ReviewModeText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ToggleButton Content="Collapse context" IsChecked="{x:Bind IsContextFoldingEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnContextFoldingClicked" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ContextFoldingText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="{x:Bind SelectedFileReviewText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ReviewActionStatusText, Mode=OneWay}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <Button Content="Stage" IsEnabled="{x:Bind HasSelectedRepositoryFile, Mode=OneWay}" Style="{StaticResource ChromeButtonStyle}" Click="OnStageSelectedFileClicked" />
                    <Button Grid.Column="1" Content="Unstage" IsEnabled="{x:Bind HasSelectedRepositoryFile, Mode=OneWay}" Style="{StaticResource ChromeButtonStyle}" Click="OnUnstageSelectedFileClicked" />
                  </Grid>
                  <TextBlock Text="{x:Bind BlameSummaryText, Mode=OneWay}"
                             Foreground="{ThemeResource TertiaryTextBrush}"
                             FontSize="10"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="View" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind VisualizationSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="{x:Bind ThemeToggleText, Mode=OneWay}" IsChecked="{x:Bind IsLightThemeEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnThemeClicked" />
                    <ToggleButton Grid.Column="1" Content="Semantic edges" IsChecked="{x:Bind IsSemanticEdgesEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticEdgesClicked" />
                  </Grid>
                  <Grid RowDefinitions="Auto,Auto" RowSpacing="3">
                    <ToggleButton Content="Canvas LOD" IsChecked="{x:Bind UseInteractiveLevelOfDetail, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnInteractiveLevelOfDetailClicked" />
                    <TextBlock Grid.Row="1"
                               Text="Use simplified node bodies while zoomed out, panning, dragging, and resizing."
                               Foreground="{ThemeResource TertiaryTextBrush}"
                               FontSize="10"
                               TextWrapping="WrapWholeWords" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Git refs" Tag="Git" IsChecked="{x:Bind IsGitVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Column="1" Content="Semantic" Tag="Semantic" IsChecked="{x:Bind IsSemanticVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="1" Content="Diagnostics" Tag="Diagnostics" IsChecked="{x:Bind IsDiagnosticVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="Review" Tag="Review" IsChecked="{x:Bind IsReviewVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="2" Content="History" Tag="History" IsChecked="{x:Bind IsHistoryVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="2" Grid.Column="1" Content="Navigation" Tag="Navigation" IsChecked="{x:Bind IsNavigationVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="3" Content="Context folds" Tag="Context" IsChecked="{x:Bind IsContextVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="3" Grid.Column="1" Content="Comments" Tag="ReviewComments" IsChecked="{x:Bind IsReviewCommentVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
    </DataTemplate>
    </ResourceDictionary>
  </Page.Resources>

  <Grid x:Name="RootShellGrid" RowDefinitions="40,*,44" Background="{ThemeResource AppBackgroundBrush}">
