<Page x:Class="SemanticDiff.App.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="using:SemanticDiff.App.Views"
      Background="{ThemeResource AppBackgroundBrush}">
  <Page.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0F14" />
          <SolidColorBrush x:Key="ChromeBrush" Color="#101721" />
          <SolidColorBrush x:Key="PanelBrush" Color="#0F151D" />
          <SolidColorBrush x:Key="PanelRaisedBrush" Color="#141C27" />
          <SolidColorBrush x:Key="CanvasBrush" Color="#0C1118" />
          <SolidColorBrush x:Key="BorderBrush" Color="#263140" />
          <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1B2430" />
          <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E6EDF5" />
          <SolidColorBrush x:Key="SecondaryTextBrush" Color="#99A6B6" />
          <SolidColorBrush x:Key="TertiaryTextBrush" Color="#6F7B8B" />
          <SolidColorBrush x:Key="AccentBrush" Color="#58A6D6" />
          <SolidColorBrush x:Key="AccentMutedBrush" Color="#183142" />
          <SolidColorBrush x:Key="PositiveBrush" Color="#55B886" />
          <SolidColorBrush x:Key="WarningBrush" Color="#D7B46A" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F6F9" />
          <SolidColorBrush x:Key="ChromeBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="PanelBrush" Color="#EEF2F6" />
          <SolidColorBrush x:Key="PanelRaisedBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="CanvasBrush" Color="#F7F9FC" />
          <SolidColorBrush x:Key="BorderBrush" Color="#C9D3E0" />
          <SolidColorBrush x:Key="SubtleBorderBrush" Color="#DDE4EE" />
          <SolidColorBrush x:Key="PrimaryTextBrush" Color="#142033" />
          <SolidColorBrush x:Key="SecondaryTextBrush" Color="#526172" />
          <SolidColorBrush x:Key="TertiaryTextBrush" Color="#7A8796" />
          <SolidColorBrush x:Key="AccentBrush" Color="#166B9A" />
          <SolidColorBrush x:Key="AccentMutedBrush" Color="#DDEFF8" />
          <SolidColorBrush x:Key="PositiveBrush" Color="#187A54" />
          <SolidColorBrush x:Key="WarningBrush" Color="#9A6D16" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="ChromeButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="11,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="CompactToggleStyle" TargetType="ToggleButton">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource AccentMutedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="CompactListViewItemStyle" TargetType="ListViewItem">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="TreeDisclosureButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{ThemeResource TertiaryTextBrush}" />
    </Style>

    <DataTemplate x:Key="ExplorerTreeItemTemplate">
      <Grid MinHeight="30"
            Padding="0,1"
            Tag="{Binding}"
            RightTapped="OnExplorerTreeNodeRightTapped">
        <Grid Margin="{Binding IndentMargin}" ColumnDefinitions="18,22,*,Auto" ColumnSpacing="7">
          <Button Content="{Binding DisclosureGlyph}"
                  Tag="{Binding}"
                  Style="{StaticResource TreeDisclosureButtonStyle}"
                  IsEnabled="{Binding HasChildren}"
                  Click="OnExplorerNodeDisclosureClicked" />
          <Grid Grid.Column="1" Width="21" Height="22" VerticalAlignment="Center">
            <Border Width="3"
                    Height="18"
                    HorizontalAlignment="Left"
                    CornerRadius="2"
                    Background="{Binding StatusBrush}" />
            <Border Width="18"
                    Height="18"
                    HorizontalAlignment="Right"
                    CornerRadius="4"
                    Background="{Binding StatusSoftBrush}"
                    BorderBrush="{Binding StatusBrush}"
                    BorderThickness="1">
              <TextBlock Text="{Binding IconGlyph}"
                         FontFamily="{Binding IconFontFamily}"
                         Foreground="{Binding StatusBrush}"
                         FontSize="12"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="{Binding IconAutomationText}"
                         ToolTipService.ToolTip="{Binding PlatformIconText}" />
            </Border>
          </Grid>
          <Grid Grid.Column="2" RowDefinitions="Auto,Auto">
            <TextBlock Text="{Binding Name}"
                       Foreground="{ThemeResource PrimaryTextBrush}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Row="1"
                       Text="{Binding DisplayPath}"
                       Foreground="{ThemeResource TertiaryTextBrush}"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis" />
          </Grid>
          <Border Grid.Column="3"
                  MinWidth="20"
                  Height="18"
                  CornerRadius="3"
                  Background="{Binding StatusSoftBrush}"
                  BorderBrush="{Binding StatusBrush}"
                  BorderThickness="1"
                  Margin="6,1,0,0"
                  VerticalAlignment="Top">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{Binding StatusBrush}"
                       FontSize="9"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Grid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SemanticItemTemplate">
      <Grid ColumnDefinitions="42,*,Auto" MinHeight="34" Padding="0,3" ColumnSpacing="8">
        <Border Width="36"
                Height="18"
                CornerRadius="3"
                Background="{ThemeResource AccentMutedBrush}"
                BorderBrush="{ThemeResource BorderBrush}"
                BorderThickness="1"
                VerticalAlignment="Top">
          <TextBlock Text="{Binding KindText}"
                     Foreground="{ThemeResource AccentBrush}"
                     FontSize="9"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </Border>
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto">
          <TextBlock Text="{Binding DisplayName}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="1"
                     Text="{Binding LocationText}"
                     Foreground="{ThemeResource TertiaryTextBrush}"
                     FontSize="10"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
        <TextBlock Grid.Column="2"
                   Text="{Binding EdgeText}"
                   Foreground="{ThemeResource TertiaryTextBrush}"
                   FontSize="10"
                   Margin="6,1,0,0"
                   VerticalAlignment="Top" />
      </Grid>
    </DataTemplate>
    </ResourceDictionary>
  </Page.Resources>

  <Grid x:Name="RootShellGrid" RowDefinitions="40,*,44" Background="{ThemeResource AppBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="LeftPaneColumn" Width="260" MinWidth="220" MaxWidth="520" />
      <ColumnDefinition x:Name="PaneSplitterColumn" Width="6" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Background="{ThemeResource ChromeBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="260,*,Auto" Padding="14,0,12,0">
        <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
          <Border Width="3" Height="18" Background="{ThemeResource AccentBrush}" CornerRadius="2" />
          <TextBlock Text="SemanticDiff"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="15"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10" VerticalAlignment="Center">
          <TextBlock Text="{x:Bind ViewModel.RepositoryName, Mode=OneWay}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Border Grid.Column="1" Width="1" Height="14" Background="{ThemeResource BorderBrush}" />
          <TextBlock Grid.Column="2"
                     Text="{x:Bind ViewModel.RepositoryContextText, Mode=OneWay}"
                     Foreground="{ThemeResource SecondaryTextBrush}"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Button Content="Prev" Style="{StaticResource ChromeButtonStyle}" Click="OnPreviousChangeClicked" IsEnabled="{x:Bind ViewModel.HasNavigableChanges, Mode=OneWay}" />
          <Button Content="Next" Style="{StaticResource ChromeButtonStyle}" Click="OnNextChangeClicked" IsEnabled="{x:Bind ViewModel.HasNavigableChanges, Mode=OneWay}" />
          <Button Content="Open" Style="{StaticResource ChromeButtonStyle}" Click="OnOpenRepositoryClicked" />
          <Button Content="Reload" Style="{StaticResource ChromeButtonStyle}" Click="OnReloadClicked" />
          <Button Content="Fit" Style="{StaticResource ChromeButtonStyle}" Click="OnFitClicked" />
          <Button Content="Layout" Style="{StaticResource ChromeButtonStyle}" Click="OnLayoutClicked" />
          <Button Content="Cancel" Style="{StaticResource ChromeButtonStyle}" Click="OnCancelClicked" IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="{ThemeResource PanelBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
          BorderThickness="0">
          <Grid RowDefinitions="Auto,*" Padding="12,12,10,10">
        <StackPanel Spacing="8">
          <TextBlock Text="Repository" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
          <Border Background="{ThemeResource PanelRaisedBrush}"
                  BorderBrush="{ThemeResource SubtleBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="5"
                  Padding="10,8">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
              <TextBlock Text="{x:Bind ViewModel.RepositoryName, Mode=OneWay}"
                         Foreground="{ThemeResource PrimaryTextBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="1"
                         Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                         Foreground="{ThemeResource SecondaryTextBrush}"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="2"
                         Text="{x:Bind ViewModel.RepositoryPathText, Mode=OneWay}"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis" />
            </Grid>
          </Border>
        </StackPanel>

        <TabView Grid.Row="1"
                 Margin="0,12,0,0"
                 IsAddTabButtonVisible="False"
                 CanDragTabs="False"
                 CanReorderTabs="False"
                 SelectedIndex="{x:Bind ViewModel.SelectedRailTabIndex, Mode=TwoWay}">
          <TabViewItem Header="Files" IsClosable="False">
            <Grid RowDefinitions="Auto,Auto,*" Padding="0,8,0,0">
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,7">
                <TextBlock Text="Changed Files" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ExplorerCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
              </Grid>
              <TextBox Grid.Row="1"
                       Text="{x:Bind ViewModel.FileSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Find file"
                       Margin="0,0,0,7" />
              <ListView Grid.Row="2"
                        ItemsSource="{x:Bind ViewModel.ExplorerTreeItems, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedExplorerTreeNode, Mode=TwoWay}"
                        ItemTemplate="{StaticResource ExplorerTreeItemTemplate}"
                        ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="Single"
                        SelectionChanged="OnExplorerTreeSelectionChanged" />
            </Grid>
          </TabViewItem>

          <TabViewItem Header="Symbols" IsClosable="False">
            <Grid RowDefinitions="Auto,Auto,*" Padding="0,8,0,0">
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,7">
                <TextBlock Text="Symbols" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SymbolCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
              </Grid>
              <TextBox Grid.Row="1"
                       Text="{x:Bind ViewModel.SymbolSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Find symbol"
                       Margin="0,0,0,7" />
              <ListView Grid.Row="2"
                        ItemsSource="{x:Bind ViewModel.SemanticItems, Mode=OneWay}"
                        ItemTemplate="{StaticResource SemanticItemTemplate}"
                        ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="Single"
                        SelectionChanged="OnSemanticSelectionChanged" />
            </Grid>
          </TabViewItem>

          <TabViewItem Header="Settings" IsClosable="False">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12" Padding="0,8,4,6">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Diff Scope" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DiffScopeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Worktree" IsChecked="{x:Bind ViewModel.IsWorktreeScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnWorktreeScopeClicked" />
                    <ToggleButton Grid.Column="1" Content="Unstaged" IsChecked="{x:Bind ViewModel.IsUnstagedScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnUnstagedScopeClicked" />
                    <ToggleButton Grid.Row="1" Content="Staged" IsChecked="{x:Bind ViewModel.IsStagedScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnStagedScopeClicked" />
                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="Branch" IsChecked="{x:Bind ViewModel.IsBranchScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnBranchScopeClicked" />
                    <ToggleButton Grid.Row="2" Grid.ColumnSpan="2" Content="Range" IsChecked="{x:Bind ViewModel.IsRangeScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnRangeScopeClicked" />
                    <TextBox Grid.Row="3"
                             Text="{x:Bind ViewModel.BaseRefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             PlaceholderText="Base ref" />
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Text="{x:Bind ViewModel.HeadRefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             PlaceholderText="Head ref" />
                  </Grid>
                  <Button Content="Apply refs" Style="{StaticResource ChromeButtonStyle}" Click="OnApplyRefsClicked" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Repository" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.WatchStatusText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                  </Grid>
                  <Grid>
                    <ToggleButton Content="Auto refresh" IsChecked="{x:Bind ViewModel.IsAutoRefreshEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnAutoRefreshClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Semantic Analysis" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SemanticAnalysisModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="MSBuild" IsChecked="{x:Bind ViewModel.IsSemanticWorkspaceModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticWorkspaceModeClicked" />
                    <ToggleButton Grid.Column="1" Content="Fast syntax" IsChecked="{x:Bind ViewModel.IsSemanticFastModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticFastModeClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Context" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DiffContextModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Changed" IsChecked="{x:Bind ViewModel.IsChangedHunksContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnChangedHunksContextClicked" />
                    <ToggleButton Grid.Column="1" Content="Full diff" IsChecked="{x:Bind ViewModel.IsFullFileDiffContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFullFileDiffContextClicked" />
                    <ToggleButton Grid.Row="1" Grid.ColumnSpan="2" Content="Current file" IsChecked="{x:Bind ViewModel.IsCurrentFileContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnCurrentFileContextClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Review" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ToggleButton Content="Noise filter" IsChecked="{x:Bind ViewModel.IsNoiseFilterEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnNoiseFilterClicked" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ReviewModeText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ToggleButton Content="Collapse context" IsChecked="{x:Bind ViewModel.IsContextFoldingEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnContextFoldingClicked" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ContextFoldingText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="{x:Bind ViewModel.SelectedFileReviewText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ReviewActionStatusText, Mode=OneWay}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <Button Content="Stage" IsEnabled="{x:Bind ViewModel.HasSelectedRepositoryFile, Mode=OneWay}" Style="{StaticResource ChromeButtonStyle}" Click="OnStageSelectedFileClicked" />
                    <Button Grid.Column="1" Content="Unstage" IsEnabled="{x:Bind ViewModel.HasSelectedRepositoryFile, Mode=OneWay}" Style="{StaticResource ChromeButtonStyle}" Click="OnUnstageSelectedFileClicked" />
                  </Grid>
                  <TextBlock Text="{x:Bind ViewModel.BlameSummaryText, Mode=OneWay}"
                             Foreground="{ThemeResource TertiaryTextBrush}"
                             FontSize="10"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="View" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.VisualizationSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="{x:Bind ViewModel.ThemeToggleText, Mode=OneWay}" IsChecked="{x:Bind ViewModel.IsLightThemeEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnThemeClicked" />
                    <ToggleButton Grid.Column="1" Content="Semantic edges" IsChecked="{x:Bind ViewModel.IsSemanticEdgesEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticEdgesClicked" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Git refs" Tag="Git" IsChecked="{x:Bind ViewModel.IsGitVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Column="1" Content="Semantic" Tag="Semantic" IsChecked="{x:Bind ViewModel.IsSemanticVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="1" Content="Diagnostics" Tag="Diagnostics" IsChecked="{x:Bind ViewModel.IsDiagnosticVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="Review" Tag="Review" IsChecked="{x:Bind ViewModel.IsReviewVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="2" Content="History" Tag="History" IsChecked="{x:Bind ViewModel.IsHistoryVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="2" Grid.Column="1" Content="Navigation" Tag="Navigation" IsChecked="{x:Bind ViewModel.IsNavigationVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="3" Grid.ColumnSpan="2" Content="Context folds" Tag="Context" IsChecked="{x:Bind ViewModel.IsContextVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabViewItem>
        </TabView>
      </Grid>
    </Border>

    <views:ResizeCursorGrid x:Name="PaneSplitter"
                Grid.Row="1"
                Grid.Column="1"
                Background="Transparent"
                PointerPressed="OnPaneSplitterPointerPressed"
                PointerMoved="OnPaneSplitterPointerMoved"
                PointerReleased="OnPaneSplitterPointerReleased"
                PointerCanceled="OnPaneSplitterPointerReleased"
                PointerCaptureLost="OnPaneSplitterPointerReleased"
                PointerEntered="OnPaneSplitterPointerEntered"
                PointerExited="OnPaneSplitterPointerExited"
                AutomationProperties.Name="Resize file explorer">
      <Border x:Name="PaneSplitterLine"
              Width="1"
              HorizontalAlignment="Center"
              Background="{ThemeResource BorderBrush}" />
    </views:ResizeCursorGrid>

    <Grid Grid.Row="1" Grid.Column="2" Background="{ThemeResource CanvasBrush}">
      <views:DiffCanvasControl x:Name="DiffCanvas" Scene="{x:Bind ViewModel.Scene, Mode=OneWay}" IsLightTheme="{x:Bind ViewModel.IsLightThemeEnabled, Mode=OneWay}" />
      <Border HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="12"
              Background="{ThemeResource ChromeBrush}"
              BorderBrush="{ThemeResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="10,7">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{x:Bind ViewModel.DocumentCountText, Mode=OneWay}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold" />
          <TextBlock Text="{x:Bind ViewModel.SemanticEdgeCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
          <TextBlock Text="{x:Bind ViewModel.ImpactSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
          <TextBlock Text="{x:Bind ViewModel.ReviewSignalText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
          <TextBlock Text="{x:Bind ViewModel.ChangeNavigationText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
          <TextBlock Text="{x:Bind ViewModel.VisualizationSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2"
          Grid.ColumnSpan="3"
            Background="{ThemeResource ChromeBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,0">
      <Grid ColumnDefinitions="*,220,360" ColumnSpacing="14" VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
          <TextBlock Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="11"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="1"
                     Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                     Foreground="{ThemeResource TertiaryTextBrush}"
                     FontSize="10"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
        <ProgressBar Grid.Column="1"
                     Height="3"
                     Maximum="1"
                     Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                     VerticalAlignment="Center" />
        <Grid Grid.Column="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
          <TextBlock Text="{x:Bind ViewModel.DiagnosticsCountText, Mode=OneWay}"
                     Foreground="{ThemeResource SecondaryTextBrush}"
                     FontSize="10"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{x:Bind ViewModel.LatestDiagnosticText, Mode=OneWay}"
                     Foreground="{ThemeResource TertiaryTextBrush}"
                     FontSize="10"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Page>
