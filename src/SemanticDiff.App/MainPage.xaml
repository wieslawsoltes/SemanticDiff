    <DataTemplate x:Key="SettingsPanelTemplate" x:DataType="viewModels:MainViewModel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12" Padding="0,8,4,6">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Diff Scope" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind DiffScopeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Worktree" IsChecked="{x:Bind IsWorktreeScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnWorktreeScopeClicked" />
                    <ToggleButton Grid.Column="1" Content="Unstaged" IsChecked="{x:Bind IsUnstagedScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnUnstagedScopeClicked" />
                    <ToggleButton Grid.Row="1" Content="Staged" IsChecked="{x:Bind IsStagedScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnStagedScopeClicked" />
                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="Branch" IsChecked="{x:Bind IsBranchScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnBranchScopeClicked" />
                    <ToggleButton Grid.Row="2" Grid.ColumnSpan="2" Content="Range" IsChecked="{x:Bind IsRangeScopeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnRangeScopeClicked" />
                    <TextBox x:Name="BaseRefTextBox"
                             Grid.Row="3"
                             Text="{x:Bind BaseRefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             PlaceholderText="Start/base ref" />
                    <TextBox x:Name="HeadRefTextBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Text="{x:Bind HeadRefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             PlaceholderText="End/head ref" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="{x:Bind ReferenceSelectorStatusText, Mode=OneWay}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{x:Bind DiffViewCacheText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Button Content="Apply refs" Style="{StaticResource ChromeButtonStyle}" Click="OnApplyRefsClicked" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Repository" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind WatchStatusText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                  </Grid>
                  <Grid>
                    <ToggleButton Content="Auto refresh" IsChecked="{x:Bind IsAutoRefreshEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnAutoRefreshClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Semantic Analysis" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind SemanticAnalysisModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="MSBuild" IsChecked="{x:Bind IsSemanticWorkspaceModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticWorkspaceModeClicked" />
                    <ToggleButton Grid.Column="1" Content="Fast syntax" IsChecked="{x:Bind IsSemanticFastModeSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticFastModeClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Layout" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind LayoutModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <ComboBox ItemsSource="{x:Bind LayoutModeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind SelectedLayoutModeOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnLayoutModeSelectionChanged" />
                  <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Text="Grouping" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind GroupingModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <ComboBox ItemsSource="{x:Bind GroupingModeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind SelectedGroupingModeOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnGroupingModeSelectionChanged" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Context" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind DiffContextModeText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Changed" IsChecked="{x:Bind IsChangedHunksContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnChangedHunksContextClicked" />
                    <ToggleButton Grid.Column="1" Content="Full diff" IsChecked="{x:Bind IsFullFileDiffContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnFullFileDiffContextClicked" />
                    <ToggleButton Grid.Row="1" Grid.ColumnSpan="2" Content="Current file" IsChecked="{x:Bind IsCurrentFileContextSelected, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnCurrentFileContextClicked" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Review" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ReviewRequestStateText, Mode=OneWay}" Foreground="{ThemeResource AccentBrush}" FontSize="10" />
                  </Grid>
                  <ComboBox ItemsSource="{x:Bind ReviewRequestStateOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind SelectedReviewRequestStateOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            Style="{StaticResource CompactComboBoxStyle}"
                            SelectionChanged="OnReviewRequestStateSelectionChanged" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ToggleButton Content="Noise filter" IsChecked="{x:Bind IsNoiseFilterEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnNoiseFilterClicked" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ReviewModeText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ToggleButton Content="Collapse context" IsChecked="{x:Bind IsContextFoldingEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnContextFoldingClicked" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ContextFoldingText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="{x:Bind SelectedFileReviewText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{x:Bind ReviewActionStatusText, Mode=OneWay}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <Button Content="Stage" IsEnabled="{x:Bind HasSelectedRepositoryFile, Mode=OneWay}" Style="{StaticResource ChromeButtonStyle}" Click="OnStageSelectedFileClicked" />
                    <Button Grid.Column="1" Content="Unstage" IsEnabled="{x:Bind HasSelectedRepositoryFile, Mode=OneWay}" Style="{StaticResource ChromeButtonStyle}" Click="OnUnstageSelectedFileClicked" />
                  </Grid>
                  <TextBlock Text="{x:Bind BlameSummaryText, Mode=OneWay}"
                             Foreground="{ThemeResource TertiaryTextBrush}"
                             FontSize="10"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="View" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{x:Bind VisualizationSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <ToggleButton Content="{x:Bind ThemeToggleText, Mode=OneWay}" IsChecked="{x:Bind IsLightThemeEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnThemeClicked" />
                    <ToggleButton Grid.Column="1" Content="Semantic edges" IsChecked="{x:Bind IsSemanticEdgesEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnSemanticEdgesClicked" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <ToggleButton Content="Git refs" Tag="Git" IsChecked="{x:Bind IsGitVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Column="1" Content="Semantic" Tag="Semantic" IsChecked="{x:Bind IsSemanticVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="1" Content="Diagnostics" Tag="Diagnostics" IsChecked="{x:Bind IsDiagnosticVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="Review" Tag="Review" IsChecked="{x:Bind IsReviewVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="2" Content="History" Tag="History" IsChecked="{x:Bind IsHistoryVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="2" Grid.Column="1" Content="Navigation" Tag="Navigation" IsChecked="{x:Bind IsNavigationVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="3" Content="Context folds" Tag="Context" IsChecked="{x:Bind IsContextVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                    <ToggleButton Grid.Row="3" Grid.Column="1" Content="Comments" Tag="ReviewComments" IsChecked="{x:Bind IsReviewCommentVisualizationEnabled, Mode=OneWay}" Style="{StaticResource CompactToggleStyle}" Click="OnVisualizationToggleClicked" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
    </DataTemplate>
    </ResourceDictionary>
  </Page.Resources>

  <Grid x:Name="RootShellGrid" RowDefinitions="40,*,44" Background="{ThemeResource AppBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="LeftPaneColumn" Width="260" MinWidth="220" MaxWidth="520" />
      <ColumnDefinition x:Name="PaneSplitterColumn" Width="6" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Background="{ThemeResource ChromeBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="260,*,Auto" Padding="14,0,12,0">
        <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
          <Border Width="3" Height="18" Background="{ThemeResource AccentBrush}" CornerRadius="2" />
          <TextBlock Text="SemanticDiff"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="15"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10" VerticalAlignment="Center">
          <TextBlock Text="{x:Bind ViewModel.RepositoryName, Mode=OneWay}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Border Grid.Column="1" Width="1" Height="14" Background="{ThemeResource BorderBrush}" />
          <TextBlock Grid.Column="2"
                     Text="{x:Bind ViewModel.RepositoryContextText, Mode=OneWay}"
                     Foreground="{ThemeResource SecondaryTextBrush}"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Button Content="Prev" Style="{StaticResource ChromeButtonStyle}" Click="OnPreviousChangeClicked" IsEnabled="{x:Bind ViewModel.HasNavigableChanges, Mode=OneWay}" />
          <Button Content="Next" Style="{StaticResource ChromeButtonStyle}" Click="OnNextChangeClicked" IsEnabled="{x:Bind ViewModel.HasNavigableChanges, Mode=OneWay}" />
          <Button Content="Open" Style="{StaticResource ChromeButtonStyle}" Click="OnOpenRepositoryClicked" />
          <Button Content="Reload" Style="{StaticResource ChromeButtonStyle}" Click="OnReloadClicked" />
          <Button Content="Fit" Style="{StaticResource ChromeButtonStyle}" Click="OnFitClicked" />
          <Button Content="Layout" Style="{StaticResource ChromeButtonStyle}" Click="OnLayoutClicked" />
          <Button Content="Cancel" Style="{StaticResource ChromeButtonStyle}" Click="OnCancelClicked" IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="{ThemeResource PanelBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
          BorderThickness="0">
          <Grid RowDefinitions="Auto,*" Padding="12,12,10,10">
        <StackPanel Spacing="8">
          <TextBlock Text="Repository" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
          <Border Background="{ThemeResource PanelRaisedBrush}"
                  BorderBrush="{ThemeResource SubtleBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="5"
                  Padding="10,8">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
              <TextBlock Text="{x:Bind ViewModel.RepositoryName, Mode=OneWay}"
                         Foreground="{ThemeResource PrimaryTextBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="1"
                         Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                         Foreground="{ThemeResource SecondaryTextBrush}"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="2"
                         Text="{x:Bind ViewModel.RepositoryPathText, Mode=OneWay}"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis" />
            </Grid>
          </Border>
        </StackPanel>

        <TabView Grid.Row="1"
                 Margin="0,12,0,0"
                 IsAddTabButtonVisible="False"
                 CanDragTabs="False"
                 CanReorderTabs="False"
                 SelectedIndex="{x:Bind ViewModel.SelectedRailTabIndex, Mode=TwoWay}">
          <TabViewItem Header="Files" IsClosable="False">
            <Grid RowDefinitions="Auto,Auto,*" Padding="0,8,0,0">
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,7">
                <TextBlock Text="Changed Files" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ExplorerCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
              </Grid>
              <TextBox x:Name="FileSearchBox"
                       Grid.Row="1"
                       Text="{x:Bind ViewModel.FileSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Find file"
                       Margin="0,0,0,7" />
              <ListView x:Name="ExplorerTreeList"
                        Grid.Row="2"
                        ItemsSource="{x:Bind ViewModel.ExplorerTreeItems, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedExplorerTreeNode, Mode=TwoWay}"
                        ItemTemplate="{StaticResource ExplorerTreeItemTemplate}"
                        ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="Single"
                        KeyDown="OnExplorerTreeKeyDown"
                        SelectionChanged="OnExplorerTreeSelectionChanged" />
            </Grid>
          </TabViewItem>

          <TabViewItem Header="Git" IsClosable="False">
            <Grid RowDefinitions="Auto,Auto,*" Padding="0,8,0,0">
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,7">
                <TextBlock Text="Git References" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.GitReferenceCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
              </Grid>
              <TextBox x:Name="GitReferenceSearchBox"
                       Grid.Row="1"
                       Text="{x:Bind ViewModel.GitReferenceSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Filter branches and review requests"
                       Margin="0,0,0,7" />
              <ListView x:Name="GitReferenceTreeList"
                        Grid.Row="2"
                        ItemsSource="{x:Bind ViewModel.GitReferenceTreeItems, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedGitReferenceTreeItem, Mode=TwoWay}"
                        ItemTemplate="{StaticResource GitReferenceTreeItemTemplate}"
                        ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="Single"
                        KeyDown="OnGitReferenceTreeKeyDown"
                        SelectionChanged="OnGitReferenceTreeSelectionChanged" />
            </Grid>
          </TabViewItem>

          <TabViewItem Header="Review" IsClosable="False">
            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" Padding="0,8,0,0">
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,7">
                <TextBlock Text="Review Threads" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ReviewThreadCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
              </Grid>
              <TextBox x:Name="ReviewSearchBox"
                       Grid.Row="1"
                       Text="{x:Bind ViewModel.ReviewSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Filter review"
                       Margin="0,0,0,7" />
              <ListView x:Name="ReviewThreadList"
                        Grid.Row="2"
                        ItemsSource="{x:Bind ViewModel.ReviewThreadItems, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedReviewThreadItem, Mode=TwoWay}"
                        ItemTemplate="{StaticResource ReviewThreadItemTemplate}"
                        ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="Single"
                        DoubleTapped="OnReviewThreadDoubleTapped"
                        KeyDown="OnReviewThreadKeyDown" />
              <TextBlock Grid.Row="3"
                         Text="{x:Bind ViewModel.ReviewPanelStatusText, Mode=OneWay}"
                         Foreground="{ThemeResource TertiaryTextBrush}"
                         FontSize="10"
                         TextTrimming="CharacterEllipsis"
                         Margin="0,7,0,5" />
              <ListView Grid.Row="4"
                        MaxHeight="170"
                        ItemsSource="{x:Bind ViewModel.SelectedReviewComments, Mode=OneWay}"
                        ItemTemplate="{StaticResource ReviewCommentItemTemplate}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="None" />
              <Grid Grid.Row="5" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" Margin="0,5,0,0">
                <TextBox Text="{x:Bind ViewModel.ReviewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="82"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Style="{StaticResource CompactTextBoxStyle}"
                         PlaceholderText="Write a review comment or reply" />
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                  <Button Content="Open" Style="{StaticResource ChromeButtonStyle}" IsEnabled="{x:Bind ViewModel.CanNavigateToSelectedReviewThread, Mode=OneWay}" Click="OnReviewOpenThreadClicked" />
                  <Button Grid.Column="1" Content="Reload" Style="{StaticResource ChromeButtonStyle}" Click="OnReviewReloadClicked" />
                  <Button Grid.Column="2" Content="Comment" Style="{StaticResource ChromeButtonStyle}" Click="OnReviewAddCommentClicked" />
                  <Button Grid.Column="3" Content="Reply" Style="{StaticResource ChromeButtonStyle}" IsEnabled="{x:Bind ViewModel.CanReplyToSelectedReviewThread, Mode=OneWay}" Click="OnReviewReplyClicked" />
                </Grid>
                <Button Grid.Row="2"
                        Content="{x:Bind ViewModel.ReviewResolveButtonText, Mode=OneWay}"
                        Style="{StaticResource ChromeButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.CanResolveSelectedReviewThread, Mode=OneWay}"
                        Click="OnReviewResolveClicked" />
              </Grid>
            </Grid>
          </TabViewItem>

          <TabViewItem Header="Symbols" IsClosable="False">
            <Grid x:Name="SymbolPanelGrid" Padding="0,8,0,0" RowSpacing="7">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="SymbolFacetsRow" Height="220" MinHeight="140" MaxHeight="420" />
                <RowDefinition Height="6" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,7">
                <TextBlock Text="Symbols" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SymbolCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" />
                <Button Grid.Column="2"
                        Content="Graph"
                        Height="24"
                        Padding="8,0"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="OnOpenFilteredSymbolGraphClicked" />
                <Button Grid.Column="3"
                        Content="Map"
                        Height="24"
                        Padding="8,0"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="OnOpenFilteredSemanticMapClicked" />
              </Grid>
              <TextBox x:Name="SymbolSearchBox"
                       Grid.Row="1"
                       Text="{x:Bind ViewModel.SymbolSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactTextBoxStyle}"
                       PlaceholderText="Find symbol, type, file, changed, linked" />
              <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="3">
                <TextBlock Text="{x:Bind ViewModel.SymbolInsightSummaryText, Mode=OneWay}"
                           Foreground="{ThemeResource SecondaryTextBrush}"
                           FontSize="10"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1"
                           Text="{x:Bind ViewModel.SymbolFilterStatusText, Mode=OneWay}"
                           Foreground="{ThemeResource TertiaryTextBrush}"
                           FontSize="9"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
              <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                  <TextBlock Text="Scope" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SymbolScopeFilters, Mode=OneWay}"
                                  ItemTemplate="{StaticResource SymbolScopeFilterTemplate}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="5" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>
                  </ScrollViewer>
                  <Button Grid.Column="2" Content="Clear" Style="{StaticResource ChromeButtonStyle}" Click="OnSymbolClearFiltersClicked" Height="24" Padding="8,0" />
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="6">
                  <Grid RowDefinitions="Auto,*" RowSpacing="4">
                    <TextBlock Text="Kinds" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="9" FontWeight="SemiBold" />
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.SymbolKindFacets, Mode=OneWay}"
                              ItemTemplate="{StaticResource SymbolKindFacetTemplate}"
                              ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              SelectionMode="None" />
                  </Grid>
                  <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="4">
                    <TextBlock Text="Files" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="9" FontWeight="SemiBold" />
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.SymbolDocumentFacets, Mode=OneWay}"
                              ItemTemplate="{StaticResource SymbolDocumentFacetTemplate}"
                              ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              SelectionMode="None" />
                  </Grid>
                </Grid>
              </Grid>

              <views:ResizeCursorGrid x:Name="SymbolFacetSplitter"
                                      Grid.Row="4"
                                      Background="Transparent"
                                      PointerPressed="OnSymbolFacetSplitterPointerPressed"
                                      PointerMoved="OnSymbolFacetSplitterPointerMoved"
                                      PointerReleased="OnSymbolFacetSplitterPointerReleased"
                                      PointerCanceled="OnSymbolFacetSplitterPointerReleased"
                                      PointerCaptureLost="OnSymbolFacetSplitterPointerReleased"
                                      PointerEntered="OnSymbolFacetSplitterPointerEntered"
                                      PointerExited="OnSymbolFacetSplitterPointerExited"
                                      AutomationProperties.Name="Resize symbol filters">
                <Border x:Name="SymbolFacetSplitterLine"
                        Height="1"
                        VerticalAlignment="Center"
                        Background="{ThemeResource BorderBrush}" />
              </views:ResizeCursorGrid>

              <ListView x:Name="SemanticItemsList"
                        Grid.Row="5"
                        ItemsSource="{x:Bind ViewModel.SemanticItems, Mode=OneWay}"
                        ItemTemplate="{StaticResource SemanticItemTemplate}"
                        ItemContainerStyle="{StaticResource CompactListViewItemStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectionMode="Single"
                        KeyDown="OnSemanticItemsKeyDown"
                        SelectionChanged="OnSemanticSelectionChanged" />
            </Grid>
          </TabViewItem>

          <TabViewItem Header="Settings" IsClosable="False">
            <ContentControl Content="{x:Bind ViewModel, Mode=OneWay}"
                            ContentTemplate="{StaticResource SettingsPanelTemplate}" />
          </TabViewItem>
        </TabView>
      </Grid>
    </Border>

    <views:ResizeCursorGrid x:Name="PaneSplitter"
                Grid.Row="1"
                Grid.Column="1"
                Background="Transparent"
                PointerPressed="OnPaneSplitterPointerPressed"
                PointerMoved="OnPaneSplitterPointerMoved"
                PointerReleased="OnPaneSplitterPointerReleased"
                PointerCanceled="OnPaneSplitterPointerReleased"
                PointerCaptureLost="OnPaneSplitterPointerReleased"
                PointerEntered="OnPaneSplitterPointerEntered"
                PointerExited="OnPaneSplitterPointerExited"
                AutomationProperties.Name="Resize file explorer">
      <Border x:Name="PaneSplitterLine"
              Width="1"
              HorizontalAlignment="Center"
              Background="{ThemeResource BorderBrush}" />
    </views:ResizeCursorGrid>

    <Grid Grid.Row="1" Grid.Column="2" RowDefinitions="38,*" Background="{ThemeResource CanvasBrush}">
      <Border Background="{ThemeResource ChromeBrush}"
              BorderBrush="{ThemeResource BorderBrush}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Button x:Name="WorkspaceTabsScrollLeftButton"
                    Content="&lt;"
                    MinWidth="30"
                    Padding="8,0"
                    Margin="4,4,0,4"
                    Style="{StaticResource ChromeButtonStyle}"
                    Click="OnWorkspaceTabsScrollLeftClicked"
                    IsEnabled="False"
                    Visibility="Collapsed"
                    AutomationProperties.Name="Scroll workspace tabs left" />
            <ListView x:Name="WorkspaceTabList"
                      Grid.Column="1"
                      ItemsSource="{x:Bind ViewModel.WorkspaceTabs, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedWorkspaceTab, Mode=TwoWay}"
                      ItemTemplate="{StaticResource WorkspaceTabHeaderTemplate}"
                      ItemContainerStyle="{StaticResource WorkspaceTabListViewItemStyle}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="4,3"
                      SelectionMode="Single"
                      ScrollViewer.HorizontalScrollMode="Enabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      Loaded="OnWorkspaceTabListLoaded"
                      SizeChanged="OnWorkspaceTabListSizeChanged"
                      SelectionChanged="OnWorkspaceTabListSelectionChanged">
              <ListView.Resources>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
              </ListView.Resources>
              <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ListView.ItemsPanel>
            </ListView>
            <Button x:Name="WorkspaceTabsScrollRightButton"
                    Grid.Column="2"
                    Content="&gt;"
                    MinWidth="30"
                    Padding="8,0"
                    Margin="0,4,4,4"
                    Style="{StaticResource ChromeButtonStyle}"
                    Click="OnWorkspaceTabsScrollRightClicked"
                    IsEnabled="False"
                    Visibility="Collapsed"
                    AutomationProperties.Name="Scroll workspace tabs right" />
          </Grid>

          <Grid Grid.Column="1"
                ColumnDefinitions="Auto,Auto"
                ColumnSpacing="6"
                Margin="4,4,0,4"
                VerticalAlignment="Center">
            <TextBlock Text="Layout"
                       Foreground="{ThemeResource TertiaryTextBrush}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      Width="148"
                      ItemsSource="{x:Bind ViewModel.LayoutModeOptions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedLayoutModeOption, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      Style="{StaticResource CompactComboBoxStyle}"
                      SelectionChanged="OnLayoutModeSelectionChanged"
                      AutomationProperties.Name="Workspace layout mode" />
          </Grid>

          <Grid Grid.Column="2"
                ColumnDefinitions="Auto,Auto"
                ColumnSpacing="6"
                Margin="10,4,0,4"
                VerticalAlignment="Center">
            <TextBlock Text="Grouping"
                       Foreground="{ThemeResource TertiaryTextBrush}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      Width="160"
                      ItemsSource="{x:Bind ViewModel.GroupingModeOptions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedGroupingModeOption, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      Style="{StaticResource CompactComboBoxStyle}"
                      SelectionChanged="OnGroupingModeSelectionChanged"
                      AutomationProperties.Name="Workspace grouping mode" />
          </Grid>

          <Button Grid.Column="3"
                  Content="Export"
                  Style="{StaticResource ChromeButtonStyle}"
                  Margin="10,4,0,4"
                  VerticalAlignment="Center"
                  AutomationProperties.Name="Export workspace graph">
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight">
                <MenuFlyoutItem Text="Save as SVG" Tag="Svg" Click="OnExportWorkspaceGraphClicked" />
                <MenuFlyoutItem Text="Save as PNG" Tag="Png" Click="OnExportWorkspaceGraphClicked" />
                <MenuFlyoutItem Text="Save as PDF" Tag="Pdf" Click="OnExportWorkspaceGraphClicked" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>

          <Button Grid.Column="4"
                  Content="Settings"
                  Style="{StaticResource ChromeButtonStyle}"
                  Margin="4,4,8,4"
                  VerticalAlignment="Center"
                  AutomationProperties.Name="Open workspace settings">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight">
                <Flyout.FlyoutPresenterStyle>
                  <Style TargetType="FlyoutPresenter">
                    <Setter Property="Padding" Value="12" />
                    <Setter Property="MaxWidth" Value="440" />
                    <Setter Property="MaxHeight" Value="760" />
                  </Style>
                </Flyout.FlyoutPresenterStyle>
                <Grid Width="396" MaxHeight="720">
                  <ContentControl Content="{x:Bind ViewModel, Mode=OneWay}"
                                  ContentTemplate="{StaticResource SettingsPanelTemplate}" />
                </Grid>
              </Flyout>
            </Button.Flyout>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid Visibility="{x:Bind ViewModel.GraphWorkspaceVisibility, Mode=OneWay}">
          <views:DiffCanvasControl x:Name="DiffCanvas" Scene="{x:Bind ViewModel.Scene, Mode=OneWay}" IsLightTheme="{x:Bind ViewModel.IsLightThemeEnabled, Mode=OneWay}" />
          <Border HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="12"
                  Background="{ThemeResource ChromeBrush}"
                  BorderBrush="{ThemeResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="5"
                  Padding="10,7">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Text="{x:Bind ViewModel.DocumentCountText, Mode=OneWay}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold" />
              <TextBlock Text="{x:Bind ViewModel.SemanticEdgeCountText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
              <TextBlock Text="{x:Bind ViewModel.ImpactSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
              <TextBlock Text="{x:Bind ViewModel.ReviewSignalText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
              <TextBlock Text="{x:Bind ViewModel.ChangeNavigationText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
              <TextBlock Text="{x:Bind ViewModel.VisualizationSummaryText, Mode=OneWay}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" />
            </StackPanel>
          </Border>
        </Grid>

        <ContentControl Visibility="{x:Bind ViewModel.AuxiliaryWorkspaceVisibility, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Content="{x:Bind ViewModel.SelectedWorkspaceTab, Mode=OneWay}"
                        ContentTemplate="{StaticResource WorkspaceTabContentTemplate}" />
      </Grid>
    </Grid>

    <Border Grid.Row="2"
          Grid.ColumnSpan="3"
            Background="{ThemeResource ChromeBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,0">
      <Grid ColumnDefinitions="*,220,360" ColumnSpacing="14" VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
          <TextBlock Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                     Foreground="{ThemeResource PrimaryTextBrush}"
                     FontSize="11"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="1"
                     Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                     Foreground="{ThemeResource TertiaryTextBrush}"
                     FontSize="10"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
        <ProgressBar Grid.Column="1"
                     Height="3"
                     Maximum="1"
                     Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                     VerticalAlignment="Center" />
        <Grid Grid.Column="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
          <TextBlock Text="{x:Bind ViewModel.DiagnosticsCountText, Mode=OneWay}"
                     Foreground="{ThemeResource SecondaryTextBrush}"
                     FontSize="10"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{x:Bind ViewModel.LatestDiagnosticText, Mode=OneWay}"
                     Foreground="{ThemeResource TertiaryTextBrush}"
                     FontSize="10"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Page>
