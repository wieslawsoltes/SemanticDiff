<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0F14"/>
      <SolidColorBrush x:Key="ChromeBrush" Color="#101721"/>
      <SolidColorBrush x:Key="PanelBrush" Color="#0F151D"/>
      <SolidColorBrush x:Key="PanelRaisedBrush" Color="#141C27"/>
      <SolidColorBrush x:Key="CanvasBrush" Color="#0C1118"/>
      <SolidColorBrush x:Key="BorderBrush" Color="#263140"/>
      <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1B2430"/>
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E6EDF5"/>
      <SolidColorBrush x:Key="SecondaryTextBrush" Color="#99A6B6"/>
      <SolidColorBrush x:Key="TertiaryTextBrush" Color="#6F7B8B"/>
      <SolidColorBrush x:Key="AccentBrush" Color="#58A6D6"/>
      <SolidColorBrush x:Key="AccentMutedBrush" Color="#183142"/>
      <SolidColorBrush x:Key="PositiveBrush" Color="#55B886"/>
      <SolidColorBrush x:Key="WarningBrush" Color="#D7B46A"/>
      <SolidColorBrush x:Key="WarningMutedBrush" Color="#352B16"/>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F6F9"/>
      <SolidColorBrush x:Key="ChromeBrush" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="PanelBrush" Color="#EEF2F6"/>
      <SolidColorBrush x:Key="PanelRaisedBrush" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="CanvasBrush" Color="#F7F9FC"/>
      <SolidColorBrush x:Key="BorderBrush" Color="#C9D3E0"/>
      <SolidColorBrush x:Key="SubtleBorderBrush" Color="#DDE4EE"/>
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="#142033"/>
      <SolidColorBrush x:Key="SecondaryTextBrush" Color="#526172"/>
      <SolidColorBrush x:Key="TertiaryTextBrush" Color="#7A8796"/>
      <SolidColorBrush x:Key="AccentBrush" Color="#166B9A"/>
      <SolidColorBrush x:Key="AccentMutedBrush" Color="#DDEFF8"/>
      <SolidColorBrush x:Key="PositiveBrush" Color="#187A54"/>
      <SolidColorBrush x:Key="WarningBrush" Color="#9A6D16"/>
      <SolidColorBrush x:Key="WarningMutedBrush" Color="#F6E9C8"/>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
  <Style x:Key="ChromeButtonStyle" TargetType="Button">
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="11,0"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}"/>
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style x:Key="CompactToggleStyle" TargetType="ToggleButton">
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Background" Value="{ThemeResource AccentMutedBrush}"/>
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style x:Key="CompactListViewItemStyle" TargetType="ListViewItem">
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0,1"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
  </Style>
  <Style x:Key="WorkspaceTabListViewItemStyle" TargetType="ListViewItem">
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0,0,4,0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
  </Style>
  <Style x:Key="GitHistoryListViewItemStyle" TargetType="ListViewItem">
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
  </Style>
  <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="8,2"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}"/>
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Background" Value="{ThemeResource PanelRaisedBrush}"/>
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
  </Style>
  <Style x:Key="TreeDisclosureButtonStyle" TargetType="Button">
    <Setter Property="Width" Value="18"/>
    <Setter Property="Height" Value="22"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="FontSize" Value="9"/>
    <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground" Value="{ThemeResource TertiaryTextBrush}"/>
  </Style>
  <Style x:Key="WorkspaceTabCloseButtonStyle" TargetType="Button">
    <Setter Property="Width" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground" Value="{ThemeResource TertiaryTextBrush}"/>
  </Style>
</ResourceDictionary>
