<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DataTemplate x:Key="GitHistoryRefBadgeTemplate">
    <Border Padding="5,1" Margin="0,0,4,0" CornerRadius="4" BorderThickness="1" Background="{Binding Background}" BorderBrush="{Binding Border}">
      <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontSize="9" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
    </Border>
  </DataTemplate>
  <DataTemplate x:Key="GitHistoryGraphPathTemplate">
    <Path Data="{Binding Data}" Stroke="{Binding Stroke}" StrokeThickness="{Binding StrokeThickness}" Opacity="{Binding Opacity}" IsHitTestVisible="False"/>
  </DataTemplate>
  <DataTemplate x:Key="FileDiffLineTemplate">
    <Grid MinHeight="22" Padding="8,1">
      <Grid ColumnDefinitions="44,44,26,*" ColumnSpacing="6">
        <TextBlock Text="{Binding OldLineNumberText}" Foreground="{ThemeResource TertiaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" HorizontalAlignment="Right"/>
        <TextBlock Grid.Column="1" Text="{Binding NewLineNumberText}" Foreground="{ThemeResource TertiaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" HorizontalAlignment="Right"/>
        <TextBlock Grid.Column="2" Text="{Binding Marker}" Foreground="{ThemeResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <TextBlock Grid.Column="3" Text="{Binding Text}" Foreground="{ThemeResource PrimaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12" TextTrimming="CharacterEllipsis"/>
      </Grid>
    </Grid>
  </DataTemplate>
  <DataTemplate x:Key="BlameCommitNodeTemplate">
    <Grid MinHeight="96" ColumnDefinitions="42,*" Padding="14,4">
      <Grid>
        <Border Width="3" Background="{Binding AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Stretch" CornerRadius="2"/>
        <Ellipse Width="15" Height="15" Fill="{Binding AccentBrush}" Stroke="{ThemeResource ChromeBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
      </Grid>
      <Border Grid.Column="1" Background="{Binding SoftBrush}" BorderBrush="{Binding AccentBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="7">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <TextBlock Text="{Binding ShortId}" Foreground="{ThemeResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding Summary}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            <Border Grid.Column="2" Background="{ThemeResource ChromeBrush}" BorderBrush="{Binding AccentBrush}" BorderThickness="1" CornerRadius="10" Padding="8,2">
              <TextBlock Text="{Binding LineCountText}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="10" FontWeight="SemiBold"/>
            </Border>
          </Grid>
          <TextBlock Grid.Row="1" Text="{Binding Author}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
          <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <TextBlock Text="{Binding LineRangeText}" Foreground="{ThemeResource TertiaryTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="10" TextTrimming="CharacterEllipsis"/>
            <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10"/>
          </Grid>
          <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock Text="{Binding CoverageText}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center"/>
            <Grid Grid.Column="1" Height="8" Background="{ThemeResource SubtleBorderBrush}" VerticalAlignment="Center">
              <Border Width="{Binding CoverageWidth}" Background="{Binding AccentBrush}" HorizontalAlignment="Left" CornerRadius="4"/>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </DataTemplate>
  <DataTemplate x:Key="BlameTimelineItemTemplate">
    <Border Width="178" MinHeight="82" Margin="0,0,8,0" Padding="10,8" CornerRadius="7" Background="{Binding SoftBrush}" BorderBrush="{Binding AccentBrush}" BorderThickness="1">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7">
          <Border Width="8" Height="{Binding MarkerHeight}" Background="{Binding AccentBrush}" CornerRadius="4" VerticalAlignment="Top"/>
          <TextBlock Grid.Column="1" Text="{Binding ShortId}" Foreground="{ThemeResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="{Binding TimeText}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="9"/>
        </Grid>
        <TextBlock Grid.Row="1" Text="{Binding Subject}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        <TextBlock Grid.Row="2" Text="{Binding Author}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
        <TextBlock Grid.Row="3" Text="{Binding BlamedLineText}" Foreground="{ThemeResource WarningBrush}" FontSize="9" FontWeight="SemiBold" Visibility="{Binding BlamedLineVisibility}"/>
      </Grid>
    </Border>
  </DataTemplate>
  <DataTemplate x:Key="ReviewThreadItemTemplate">
    <Grid MinHeight="46" Padding="8,5">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <TextBlock Text="{Binding KindText}" Foreground="{ThemeResource AccentBrush}" FontSize="10" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding Title}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
        <Border Grid.Column="1" MinWidth="20" Height="18" CornerRadius="4" Background="{ThemeResource AccentMutedBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
          <TextBlock Text="{Binding BadgeText}" Foreground="{ThemeResource AccentBrush}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0"/>
        </Border>
        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding DetailText}" Foreground="{ThemeResource TertiaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="6">
          <TextBlock Text="{Binding PreviewText}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
          <TextBlock Grid.Column="1" Text="resolved" Foreground="{ThemeResource PositiveBrush}" FontSize="9" FontWeight="SemiBold" Visibility="{Binding ResolvedVisibility}"/>
        </Grid>
      </Grid>
    </Grid>
  </DataTemplate>
  <DataTemplate x:Key="ReviewCommentItemTemplate">
    <Border Background="{ThemeResource PanelRaisedBrush}" BorderBrush="{ThemeResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
      <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
          <TextBlock Text="{Binding HeaderText}" Foreground="{ThemeResource PrimaryTextBrush}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
          <TextBlock Grid.Column="1" Text="system" Foreground="{ThemeResource WarningBrush}" FontSize="9" Visibility="{Binding SystemVisibility}"/>
        </Grid>
        <TextBlock Grid.Row="1" Text="{Binding Body}" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" TextWrapping="WrapWholeWords"/>
      </Grid>
    </Border>
  </DataTemplate>
</ResourceDictionary>
